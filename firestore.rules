rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Replace with your admin Gmail address
    function isAdmin() {
      return request.auth != null
        && (request.auth.token.email == 'admin@gmail.com' || request.auth.token.email == 'rasailykaran944@gmail.com');
    }

    function isValidAppointment() {
      let data = request.resource.data;
      return data.keys().hasAll(['patientName', 'phone', 'date', 'status'])
        && data.patientName is string
        && data.patientName.size() > 0
        && data.phone is string
        && data.phone.size() > 0
        && data.status == 'pending';
    }

    // Public readable CMS content
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /doctors/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /departments/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /faq/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public can create appointments only
    match /appointments/{docId} {
      allow read: if isAdmin();
      allow create: if isValidAppointment();
      allow update, delete: if isAdmin();
    }

    // Admin-only collections
    match /patients/{docId} {
      allow read, write: if isAdmin();
    }

    match /inventory/{docId} {
      allow read, write: if isAdmin();
    }

    match /billing/{docId} {
      allow read, write: if isAdmin();
    }

    match /dues/{docId} {
      allow read, write: if isAdmin();
    }

    match /staff/{docId} {
      allow read, write: if isAdmin();
    }

    match /users/{docId} {
      allow read, write: if isAdmin();
    }

    match /activityLogs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
